  "thatched_hut_diary": {
    "options": [
      {
        "text": "【拾取】把日记收起来",
        "target_room": "thatched_hut_drawer",
        "effects": {
          "items": {
            "add": [
              "old_diary"
            ]
          },
          "flags": {
            "has_diary": true,
            "diary_unread": true
          },
          "notes": {
            "add": [
              {
                "id": "diary_1",
                "title": "残页一：关于蜡烛",
                "content": "谢天谢地，我从黑市买到的凝魔烛还在烧。只要这支蜡烛不灭，林子里的哥布林和游荡的僵尸就不敢破窗进来。\n\n烛台上那些卢恩符文能极大延长燃烧时间——虽然我看不懂它们的意思，但卖给我的商人说，这些符文比蜡烛本身值钱十倍。"
              },
              {
                "id": "diary_2",
                "title": "残页二：关于时局",
                "content": "教皇厅的圣军又征税了。领主大人为了筹集对抗「北境魔潮」的军费，把面包的价格翻了三倍。\n\n村里已经有人开始啃树皮了。我不确定是北边的怪物先打过来，还是我们自己先饿死。"
              },
              {
                "id": "diary_3",
                "title": "残页三：关于地窖",
                "content": "不行，我必须得离开了。走之前，我把备用装备、几瓶实验药剂和仅剩的十几枚铜币锁在了屋后的旧地窖里。\n\n黑森林越来越不安全了。如果我能活着回来，我会用那把生锈的钥匙重新打开它。\n\n如果我回不来……愿后来者能拿着它们，逃往最近的风息村。"
              }
            ]
          }
        }
      },
      {
        "text": "【返回】回到床边",
        "target_room": "thatched_hut",
        "effects": {}
      }
    ]
  },
